# ============================================================
# DOMANI — variables de entorno (ejemplo)
# Copia este archivo a .env.local en apps/web y rellena los valores.
# NUNCA subas claves reales al repo.
# ============================================================

# --- Frontend (apps/web) — solo claves PÚBLICAS ---
VITE_SUPABASE_URL="https://zulpnimnphycnbvhvnet.supabase.co"
VITE_SUPABASE_ANON_KEY="<publishable-anon-key>"

# --- Workers / Edge (apps/workers) — claves PRIVADAS, nunca al cliente ---
# La service_role es el ÚNICO camino para mover Aurelios. Jamás exponer al frontend.
SUPABASE_URL="https://zulpnimnphycnbvhvnet.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
